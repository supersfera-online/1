def backward_chain(goals, actions, state, depth=10):
    # Базовый случай: все цели достигнуты
    if all(g in state for g in goals):
        return []
    
    # Защита от бесконечного цикла
    if depth == 0:
        return None
    
    for action in actions:
        # ИЗМЕНЕНИЕ: Действие подходит, если оно достигает ХОТЯ БЫ ОДНОЙ цели
        if any(e in goals for e in action.eff):
            new_goals = goals.copy()
            
            # Удаляем из целей те, которые покрываются этим действием
            for e in action.eff:
                if e in new_goals:
                    new_goals.remove(e)
                    
            # Добавляем в цели пререквизиты действия, которых еще нет в начальном состоянии
            new_goals.extend([p for p in action.pre if p not in state])
            
            # Рекурсивный поиск
            plan = backward_chain(new_goals, actions, state, depth - 1)
            
            if plan is not None:
                # ИЗМЕНЕНИЕ: Собираем план сразу в хронологическом (прямом) порядке
                return plan + [action.name]
                
    return None

