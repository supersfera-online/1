import heapq

class InformationRemnant:
    """
    Материя как информационный остаток (+2).
    Действие не просто меняет состояние, оно несет 'информационную массу'.
    """
    def __init__(self, name, preconditions, effects, complexity=1):
        self.name = name
        self.pre = set(preconditions)
        self.eff = set(effects)
        # Информационная плотность остатка (complexity)
        self.mass = complexity

class SupersphereEngine:
    """
    Двигатель Хаоса для поиска стабильных структур в океане возможностей.
    Применяет теорию Славы для оптимизации логического вывода.
    """
    def __init__(self, remnants):
        self.remnants = remnants
        # Константа движения c (затраты на один квант времени)
        self.c = 1 

    def get_entropic_pressure(self, goals, initial_state):
        """
        Эвристика: измеряет градиент энтропии. 
        Чем меньше условий осталось выполнить, тем ниже давление (цель ближе).
        """
        return len(goals - initial_state)

    def evolve(self, target_information, vacuum_state):
        """
        Процесс развертывания Вселенной от цели назад (антиматерия) 
        к источнику (Суперсфера).
        """
        target_info = set(target_information)
        initial_symmetry = set(vacuum_state)

        # Очередь приоритетов: (Энтропийное давление, затраченное время, план, текущие цели)
        # Гравитация информации тянет нас к наиболее вероятному пути
        chaos_frontier = []
        initial_pressure = self.get_entropic_pressure(target_info, initial_symmetry)
        
        # (Приоритет, Стоимость времени, Список действий, Текущий набор целей)
        heapq.heappush(chaos_frontier, (initial_pressure, 0, [], target_info))

        # Мемоизация для аннигиляции повторяющихся конфигураций хаоса
        seen_symmetries = set()

        while chaos_frontier:
            pressure, time_elapsed, current_structure, current_goals = heapq.heappop(chaos_frontier)

            # Если цели достигнуты (структура стабильна в вакууме)
            if not current_goals or current_goals.issubset(initial_symmetry):
                return current_structure[::-1] # Разворачиваем временной вектор для материи

            # Аннигиляция циклов: если мы уже видели эту сложность, не тратим c
            state_signature = tuple(sorted(list(current_goals)))
            if state_signature in seen_symmetries:
                continue
            seen_symmetries.add(state_signature)

            for action in self.remnants:
                # Если флуктуация Хаоса (действие) дает нужный информационный эффект
                if action.eff & current_goals:
                    # Движение по вектору времени назад: убираем эффект, добавляем причины
                    next_goals = (current_goals - action.eff) | action.pre
                    # Убираем то, что уже есть в начальной Суперсфере
                    next_goals = next_goals - initial_symmetry

                    # Расчет новой энтропийной плотности
                    # Мы учитываем стоимость движения (c) и информационную массу (mass)
                    new_time = time_elapsed + self.c
                    new_pressure = self.get_entropic_pressure(next_goals, initial_symmetry) + new_time / action.mass
                    
                    new_structure = current_structure + [action.name]
                    
                    heapq.heappush(chaos_frontier, (new_pressure, new_time, new_structure, next_goals))

        return None

